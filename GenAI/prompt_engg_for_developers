# Set up hugging face inference 
import os
from huggingface_hub import InferenceClient

client = InferenceClient()

# Modified helper fn for creating chatbot
def get_completion(chats, model="openai/gpt-oss-120b", temperature=0):
    
    response = client.chat.completions.create(
        model=model,
        messages=chats, # complete chats for contextual awareness 
        temperature=temperature, # degree of randomness of model's output
    )
    
    assistant_reply = response.choices[0].message['content']
    return assistant_reply


